# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase
# (Project Settings > API). A anon key é pública por design — a segurança
# real vem das políticas RLS em supabase/schema.sql.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica-aqui
